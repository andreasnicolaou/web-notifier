{
  "name": "@andreasnicolaou/web-notifier",
  "version": "2.1.1",
  "description": "A lightweight, RxJS-based wrapper around the browser Notification API with permission handling, auto-dismiss, delay, a Promise-based API and event callbacks.",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "browser": "dist/index.umd.min.js",
  "unpkg": "dist/index.umd.min.js",
  "jsdelivr": "dist/index.umd.min.js",
  "private": false,
  "types": "dist/index.d.ts",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build:rollup": "rollup -c",
    "build": "npm run clean && npm run build:rollup",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "format": "prettier --write .",
    "lint": "eslint --fix",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/andreasnicolaou/web-notifier.git"
  },
  "bugs": {
    "url": "https://github.com/andreasnicolaou/web-notifier/issues"
  },
  "author": "Andreas Nicolaou <anicolaou66@gmail.com>",
  "license": "MIT",
  "jest": {
    "transform": {
      "^.+\\.(ts)$": [
        "ts-jest"
      ]
    },
    "testEnvironment": "jsdom",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/"
    ]
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.4.1",
    "prettier": "3.8.1",
    "rimraf": "^6.1.3",
    "rollup": "^4.59.0",
    "rollup-plugin-dts": "^6.4.1",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "browser",
    "web",
    "notification",
    "notifications",
    "notification-api",
    "web-notifications",
    "desktop-notifications",
    "rxjs",
    "observable",
    "promise",
    "typescript",
    "permission",
    "permission-handling",
    "auto-dismiss",
    "event-driven",
    "andreasnicolaou"
  ],
  "dependencies": {
    "rxjs": "^7.8.2"
  }
}
